<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:background="@color/background_search"
    android:layout_height="match_parent"
    tools:context=".SearchActivity">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageButton
            android:id="@+id/back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@null"
            android:foreground="?attr/selectableItemBackground"
            android:src="@drawable/ic_back"
            tools:ignore="ContentDescription,SpeakableTextPresentCheck" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/search"
            android:layout_marginStart="50dp"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/ys_display_medium"
            android:textSize="@dimen/text"
            android:textColor="@color/black"
            />
    </FrameLayout>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/padding"
        android:orientation="horizontal">
        <EditText
            android:id="@+id/inputSearch"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="@string/input_hint"
            android:maxLines="1"
            android:layout_weight="1"
            android:inputType="text"
            android:background= "@drawable/edit_text"
            android:textColor="@color/black_button"
            android:fontFamily="@font/ys_display_medium"
            android:textColorHint="@color/search_text_tint"
            android:drawableStart="@drawable/ic_baseline_search_"
            android:drawablePadding="@dimen/icon_drawable"
            android:paddingStart= "@dimen/icon_drawable"
            tools:ignore="InefficientWeight,RtlSymmetry" />
        <ImageButton
            android:id="@+id/clear_text"
            style="@style/ButtonSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center"
            android:src="@drawable/ic_clear_text"
            android:visibility="gone"
            android:layout_marginEnd="@dimen/padding"
            tools:ignore="ContentDescription,SpeakableTextPresentCheck,TouchTargetSizeCheck" />
    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/track_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />


</LinearLayout>